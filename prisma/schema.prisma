generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id          Int      @id @default(autoincrement())
  title_tr    String
  title_en    String
  desc_tr     String
  desc_en     String
  image       String?  // Cover image
  images      String?  // Additional gallery images (comma-separated URLs)
  category    String   @default("genel")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Faq {
  id          Int      @id @default(autoincrement())
  question_tr String
  question_en String
  answer_tr   String
  answer_en   String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

