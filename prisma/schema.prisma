generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id          Int      @id @default(autoincrement())
  title_tr    String
  title_en    String
  desc_tr     String
  desc_en     String
  image       String?  // Cover image
  images      String?  // Additional gallery images (comma-separated URLs)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
